{
  "name": "claude-slack-event-channel-mcp",
  "version": "0.0.1",
  "description": "Slack -> Claude Code channel MCP server (Socket Mode)",
  "type": "module",
  "private": true,
  "module": "main.ts",
  "bin": {
    "claude-slack-event-channel-mcp": "main.ts"
  },
  "scripts": {
    "start": "bun run main.ts",
    "dev": "bun --watch main.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write ."
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3"
  }
}
