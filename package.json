{
  "name": "claude-slack-event-channel-mcp",
  "version": "0.0.1",
  "description": "Slack -> Claude Code channel MCP server (Socket Mode)",
  "type": "module",
  "license": "MIT",
  "author": "jacobycwang",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jacobycwang/claude-slack-event-channel-mcp.git"
  },
  "homepage": "https://github.com/jacobycwang/claude-slack-event-channel-mcp#readme",
  "bugs": {
    "url": "https://github.com/jacobycwang/claude-slack-event-channel-mcp/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "claude-code",
    "slack",
    "socket-mode"
  ],
  "module": "main.ts",
  "bin": {
    "claude-slack-event-channel-mcp": "dist/main.js"
  },
  "files": [
    "dist",
    "README.md",
    ".env.example"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "bun run main.ts",
    "dev": "bun --watch main.ts",
    "build": "bun build main.ts --target=node --outfile=dist/main.js",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "prepublishOnly": "bun run build",
    "release": "release-it"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@release-it/conventional-changelog": "^11.0.1",
    "@types/bun": "^1.3.14",
    "release-it": "^20.2.0",
    "typescript": "^6.0.3"
  }
}
