# App-Level Token (xapp-...), needs connections:write scope, used to enable Socket Mode
SLACK_APP_TOKEN=xapp-...

# Bot token (xoxb-...), scopes: users:read, channels:read, groups:read. Optional.
# When set, user/channel IDs are resolved to human-readable names before forwarding
SLACK_BOT_TOKEN=

# Forward events only from these channels (channel ID, e.g. C0123ABC, comma-separated). Empty = all channels
SLACK_WATCH_CHANNELS=

# Sender allowlist (user ID or bot_id, comma-separated). Empty = allow all
# Security note: channel messages become Claude's input (prompt injection entry point); always allowlist when listening to human messages
SLACK_ALLOWED_SENDERS=

# Content keyword filter (case-insensitive, comma-separated). Empty = forward all messages
# Only messages whose content contains at least one keyword are forwarded, e.g. "Human Security"
SLACK_CONTENT_FILTERS=

# Event type whitelist (comma-separated, e.g. message,reaction_added,reaction_removed). Empty = allow all
SLACK_EVENT_TYPES=
